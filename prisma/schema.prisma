datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  COORDENADOR
  AUXILIAR
}

enum Semester {
  ALL
  SEMESTER1
  SEMESTER2
  SEMESTER3
  SEMESTER4
  SEMESTER5
  SEMESTER6
  ESPECIAL
}

model User {
  id           Int            @id @default(autoincrement())
  imageUrl     String?        @db.VarChar(2048)
  name         String         @db.VarChar(120)
  email        String         @unique @db.VarChar(191)
  password     String         @db.VarChar(255)
  role         Role
  refreshToken RefreshToken[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([role])
  @@index([createdAt])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  tokenHash String   @unique @db.Char(64)
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

model Course {
  id          Int           @id @default(autoincrement())
  name        String        @unique @db.VarChar(80)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  Event       Event[]
  Participant Participant[]

  @@index([createdAt])
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(80)
  Event     Event[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model Location {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(80)
  Event     Event[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model Carousel {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(80)
  imageUrl  String   @db.VarChar(2048)
  isActive  Boolean  @default(false)
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([order])
  @@index([isActive])
}

model Event {
  id                  Int       @id @default(autoincrement())
  name                String    @db.VarChar(140)
  description         String    @db.Text
  imageUrl            String    @db.VarChar(2048)
  courseId            Int?
  course              Course?   @relation(fields: [courseId], references: [id], onDelete: SetNull)
  semester            Semester?
  maxParticipants     Int
  currentParticipants Int       @default(0)
  isRestricted        Boolean
  locationId          Int
  location            Location  @relation(fields: [locationId], references: [id], onDelete: Restrict)
  customLocation      String?   @db.VarChar(140)

  speakerName  String        @db.VarChar(120)
  startDate    DateTime
  startTime    DateTime
  endTime      DateTime
  duration     Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  categoryId   Int?
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  participants Participant[]
  Certificate  Certificate[]

  @@index([categoryId])
  @@index([locationId])
  @@index([isRestricted])
  @@index([courseId, semester, startDate])
  @@fulltext([name, description])
}

model Participant {
  id              Int           @id @default(autoincrement())
  name            String        @db.VarChar(120)
  email           String        @db.VarChar(191)
  courseId        Int?
  course          Course?       @relation(fields: [courseId], references: [id], onDelete: SetNull)
  semester        Semester?
  ra              String?       @db.VarChar(32)
  isPresent       Boolean       @default(false)
  certificateSent Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  eventId         Int
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  Certificate     Certificate[]

  @@unique([eventId, email])
  @@index([eventId, isPresent])
  @@index([createdAt])
}

model Certificate {
  id            Int         @id @default(autoincrement())
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  participantId Int
  event         Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId       Int
  tokenHash     String      @unique @db.Char(64)
  issuedAt      DateTime    @default(now())

  @@unique([participantId, eventId])
  @@index([eventId])
}
